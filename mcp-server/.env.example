# --- SurakshaMCP server config ---

# URL of the Python inference service (YOLOv8 + language-ID + TTS)
INFERENCE_URL=http://localhost:8000

# API key clients must present to call heavy tools (see infra/auth.guard.ts)
MCP_API_KEY=dev-key-change-me

# Server
PORT=3000
NODE_ENV=development
# @nitrostack/core defaults to 'localhost' if unset. Only needed for Docker/remote hosting
# (bind-all so the published port is reachable from outside the container); leave unset
# for plain local `npm run dev`.
# HOST=0.0.0.0

# Optional: path prefix for served audio alert files
AUDIO_PUBLIC_BASE=http://localhost:8000/audio

# SQLite DB for incidents / trainings / alerts (powers ESG-BRSR reporting).
# Default: ./data/suraksha.db — use ':memory:' for throwaway runs.
SURAKSHA_DB_PATH=./data/suraksha.db

# --- WhatsApp alerts via Twilio (optional) ---
# Leave unset for demo: send_whatsapp_alert then returns a dry-run payload instead of sending.
# Twilio sandbox: https://www.twilio.com/console/sms/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
